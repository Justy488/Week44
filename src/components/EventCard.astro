---
const { title, image, slug, sectionId } = Astro.props;
---

<a href={"/events/" + slug} class="event-card-link">
  <div class="event-card">
    <img src={image} alt={title} />
    <p>{title}</p>
    <button>Tilmeld dig her</button>
    <a href={"/kalender#" + sectionId} class="scroll-btn">Les mer ↓</a>
  </div>
</a>

<style>
  .event-card-link {
    text-decoration: none;
    color: inherit;
  }
  .cards {
    display: flex;
    flex-direction: row;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
  }

  .event-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    background-color: white;
    border-radius: 20px;
    padding: 16px;
    width: 280px;
  }

  .event-card img {
    width: 100%;
    border-radius: 12px;
    object-fit: cover;
    height: 200px;
  }
  .event-card h3 {
    font-size: 3em;
    font-weight: normal;
    font-family: Georgia, serif;
    margin: 0;
  }

  .event-card p {
    font-size: 2rem;
    color: #000000;
    text-align: center;
    margin: 0;
  }

  .event-card button {
    border: 3px solid #b8965a;
    background-color: #fbfbe7;
    padding: 10px 30px;
    border-radius: 30px;
    cursor: pointer;
    color: #b8965a;
    font-size: 0.9rem;
    width: 100%;
  }

  .event-card button:hover {
    background-color: #c0dae0;
    border: 3px solid #fbfbe7;
    color: #fbfbe7;
  }
</style>
